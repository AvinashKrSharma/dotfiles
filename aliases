# Some handy goto directories
alias c=clear
alias d="cd ~/dotfiles"
alias dv="cd ~/dotfiles && nvim"
alias e="exit"

# Git
alias ga='git add '
alias gaa='git add --all'
alias gb='git branch'
alias gc='git commit -v'
alias gcb='git checkout -b'
alias gclean='git clean -fd'
alias gcm='git commit -m'
alias gco='git checkout'
alias gd='git diff'
alias gdca='git diff --cached'
alias ggpull='git pull origin "$(git rev-parse --abbrev-ref HEAD)"'
alias ggpush='git push origin "$(git rev-parse --abbrev-ref HEAD)"'
alias glol='git log --graph --oneline --decorate --color'
alias gp='git push'
alias gs='git status'
alias gst='git status'
alias gu=gitundo
gitundo() { git reset --hard $(git rev-parse --abbrev-ref HEAD)@{${1-1}};  };

#Nvim
alias v='nvim'
alias vi='nvim'
alias vim='nvim'
